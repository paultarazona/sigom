# ─── Database ────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sigom?schema=public"

# ─── JWT ──────────────────────────────────
JWT_SECRET="cambiar-por-secreto-seguro-en-produccion"

# ─── Server ───────────────────────────────
PORT=3001
SISCON_INTEGRATION_USER_EMAIL=siscon-integration@sigom.internal
SISCON_HMAC_SECRET=replace-with-inbound-secret
SISCON_OUTBOUND_HMAC_SECRET=replace-with-outbound-secret
SISCON_HMAC_MAX_AGE_SECONDS=300
SISCON_API_URL=http://localhost:3017/api/v1/integrations/sigom/work-order-events
SISCON_TIMEOUT_MS=5000
SISCON_MAX_RETRIES=8
SISCON_OUTBOX_INTERVAL_MS=10000
SISCON_OUTBOX_LEASE_MS=60000

# ─── File Uploads ─────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760
