generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(uuid()) @db.Uuid
  email                 String            @unique @db.VarChar(255)
  passwordHash          String            @map("password_hash") @db.VarChar(255)
  firstName             String            @map("first_name") @db.VarChar(100)
  lastName              String            @map("last_name") @db.VarChar(100)
  role                  UserRole          @default(TECHNICIAN)
  isActive              Boolean           @default(true) @map("is_active")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  crewMembers           CrewMember[]
  ledCrews              Crew[]            @relation("CrewLeader")
  evidence              Evidence[]
  inspections           Inspection[]
  assignedByAssignments OrderAssignment[] @relation("OrderAssignmentAssignedBy")
  technicianAssignments OrderAssignment[] @relation("OrderAssignmentTechnician")
  assignedOrders        WorkOrder[]       @relation("AssignedTo")
  cancelledOrders       WorkOrder[]       @relation("CancelledBy")
  closedOrders          WorkOrder[]       @relation("ClosedBy")
  createdOrders         WorkOrder[]       @relation("CreatedBy")

  @@map("users")
}

model WorkOrder {
  id                 String            @id @default(uuid()) @db.Uuid
  code               String            @unique @db.VarChar(20)
  type               WorkOrderType
  priority           WorkOrderPriority @default(MEDIUM)
  status             WorkOrderStatus   @default(PENDING)
  initialObservation String?           @map("initial_observation")
  finalDiagnosis     String?           @map("final_diagnosis")
  solutionApplied    String?           @map("solution_applied")
  scheduledAt        DateTime?         @map("scheduled_at")
  startedAt          DateTime?         @map("started_at")
  resolvedAt         DateTime?         @map("resolved_at")
  closedAt           DateTime?         @map("closed_at")
  cancelledAt        DateTime?         @map("cancelled_at")
  sourceSystem       String            @default("SIGOM") @map("source_system") @db.VarChar(20)
  incidentId         String?           @map("incident_id") @db.Uuid
  incidentCode       String?           @map("incident_code") @db.VarChar(20)
  zoneId             String            @map("zone_id") @db.Uuid
  supplyId           String?           @map("supply_id") @db.Uuid
  meterId            String?           @map("meter_id") @db.Uuid
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  createdById        String            @map("created_by_id") @db.Uuid
  assignedToId       String?           @map("assigned_to_id") @db.Uuid
  closedById         String?           @map("closed_by_id") @db.Uuid
  cancelledById      String?           @map("cancelled_by_id") @db.Uuid
  evidence           Evidence[]
  inspections        Inspection[]
  assignments        OrderAssignment[]
  assignedTo         User?             @relation("AssignedTo", fields: [assignedToId], references: [id])
  cancelledBy        User?             @relation("CancelledBy", fields: [cancelledById], references: [id])
  closedBy           User?             @relation("ClosedBy", fields: [closedById], references: [id])
  createdBy          User              @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([zoneId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("work_orders")
}

model OrderAssignment {
  id           String    @id @default(uuid()) @db.Uuid
  workOrderId  String    @map("work_order_id") @db.Uuid
  technicianId String    @map("technician_id") @db.Uuid
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  assignedById String    @map("assigned_by_id") @db.Uuid
  assignedBy   User      @relation("OrderAssignmentAssignedBy", fields: [assignedById], references: [id])
  technician   User      @relation("OrderAssignmentTechnician", fields: [technicianId], references: [id])
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([technicianId])
  @@map("order_assignments")
}

model Inspection {
  id             String           @id @default(uuid()) @db.Uuid
  code           String           @unique @db.VarChar(20)
  workOrderId    String           @map("work_order_id") @db.Uuid
  inspectionType String           @map("inspection_type") @db.VarChar(100)
  result         InspectionResult
  observation    String?
  registeredById String           @map("registered_by_id") @db.Uuid
  registeredAt   DateTime         @default(now()) @map("registered_at")
  evidence       Evidence[]
  registeredBy   User             @relation(fields: [registeredById], references: [id])
  workOrder      WorkOrder        @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([registeredById])
  @@map("inspections")
}

model Evidence {
  id             String      @id @default(uuid()) @db.Uuid
  code           String      @unique @db.VarChar(20)
  workOrderId    String      @map("work_order_id") @db.Uuid
  inspectionId   String?     @map("inspection_id") @db.Uuid
  filePath       String      @map("file_path") @db.VarChar(500)
  mimeType       String      @map("mime_type") @db.VarChar(100)
  originalName   String      @map("original_name") @db.VarChar(255)
  observation    String?
  registeredById String      @map("registered_by_id") @db.Uuid
  registeredAt   DateTime    @default(now()) @map("registered_at")
  inspection     Inspection? @relation(fields: [inspectionId], references: [id])
  registeredBy   User        @relation(fields: [registeredById], references: [id])
  workOrder      WorkOrder   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([inspectionId])
  @@map("evidence")
}

model Crew {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @db.VarChar(100)
  leaderId  String       @map("leader_id") @db.Uuid
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  members   CrewMember[]
  leader    User         @relation("CrewLeader", fields: [leaderId], references: [id])

  @@map("crews")
}

model CrewMember {
  id     String @id @default(uuid()) @db.Uuid
  crewId String @map("crew_id") @db.Uuid
  userId String @map("user_id") @db.Uuid
  crew   Crew   @relation(fields: [crewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([crewId, userId])
  @@map("crew_members")
}

model MaintenancePlan {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(20)
  name          String   @db.VarChar(200)
  description   String?
  frequencyDays Int      @map("frequency_days")
  startDate     DateTime @map("start_date") @db.Date
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("maintenance_plans")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  TECHNICIAN
  VIEWER
}

enum WorkOrderStatus {
  PENDING
  ASSIGNED
  IN_FIELD
  SUSPENDED
  RESOLVED
  CLOSED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkOrderType {
  METER_INSPECTION
  METER_REPLACEMENT
  CONSUMPTION_VERIFICATION
  PREVENTIVE_MAINTENANCE
  CORRECTIVE_MAINTENANCE
  CONNECTION_VERIFICATION
  CLAIM_ATTENTION
  DISCONNECTION_RECONNECTION
}

enum InspectionResult {
  METER_DAMAGED
  METER_TAMPERED
  READING_CORRECT
  IRREGULAR_CONNECTION
  INTERNAL_LEAK
  CUSTOMER_ABSENT
  NO_ISSUE_FOUND
  ADDITIONAL_VISIT_REQUIRED
}
